# ─── Supabase ────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret      # min 32 chars

# ─── JWT (both secrets required) ─────────────────────────────
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret   # min 32 chars

# ─── Supabase keys ─────────────────────────────────────────────
# HIGH FIX 7: only SUPABASE_SERVICE_KEY is read by the code (core/database/
# client.ts / core/config/env.ts). A previous version of this file also
# listed the legacy name SUPABASE_SERVICE_ROLE_KEY, which silently did
# nothing if copied instead — the app would fail with cryptic Supabase auth
# errors at runtime, not a clear "missing env var" message at startup.
SUPABASE_SERVICE_KEY=your-service-role-key
# ⚠ REQUIRED IN PRODUCTION — falling back to the service-role key bypasses
# Row Level Security on every client-facing query. Startup will fail with a
# Zod validation error if this is missing in a production environment.
# Optional in dev/test (service-role key is used as fallback).
SUPABASE_ANON_KEY=your-anon-public-key

# ─── Resend ──────────────────────────────────────────────────
# HIGH FIX 6: when both of these are set, new signups receive a real
# verification email and stay unverified until they click the link.
# Leave either unset (e.g. local dev) and new users are auto-verified
# instead, with a warning logged on every signup — see registerUser()
# in backend/src/modules/auth/auth.service.ts.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# ⚠ Must be EMAIL_FROM (not FROM_EMAIL) — code reads process.env.EMAIL_FROM
EMAIL_FROM=noreply@yourdomain.com

# ─── App ─────────────────────────────────────────────────────
# ⚠ Must be FRONTEND_URL (not APP_URL) — used to build email verification links
FRONTEND_URL=https://yourdomain.com
ALLOWED_ORIGIN=https://yourdomain.com
PORT=3000
NODE_ENV=production
# M1: set at build time, e.g. --build-arg VERSION=$(git rev-parse --short HEAD)
VERSION=unknown

# Extra CORS origins — comma-separated, exact origins including scheme.
# Use this to whitelist Vercel preview URLs or staging domains without
# a code deploy. Never use a wildcard. Leave empty in production unless needed.
# Example: https://vachix-pr-42.vercel.app,https://staging.vachix.in
EXTRA_ALLOWED_ORIGINS=

# ─── Voice (optional) ─────────────────────────────────────────
# If unset, AI replies fall back to the browser's built-in
# speechSynthesis (Web Speech API) — no SaaS-grade voice.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Hindi/Hinglish voice (Multi-language interview mode) — optional
SARVAM_API_KEY=
SARVAM_TTS_SPEAKER=shubh
SARVAM_TTS_MODEL=bulbul:v3
# Set to 'true' to use Sarvam as the primary TTS provider for ALL languages
# (English included, using en-IN accent on Bulbul v3), with ElevenLabs as
# fallback. Default 'false' keeps ElevenLabs primary for English (legacy).
SARVAM_PRIMARY=true
# Sarvam language code for English when SARVAM_PRIMARY=true. en-IN = Indian-English.
SARVAM_EN_LANG_CODE=en-IN

# Voice usage ledger — monthly caps per plan (seconds). -1 = unlimited.
# Starter: 600 s = 10 min  |  Pro: 3600 s = 60 min  |  Elite: unlimited
VOICE_CAP_STARTER=600
VOICE_CAP_PRO=3600
# Hard ceiling on bonus voice seconds a user can accumulate via streak rewards.
MAX_BONUS_VOICE_SECONDS=3600
# Bonus seconds credited per streak milestone (7 / 14 / 21 / …). Default 5 min.
STREAK_VOICE_BONUS_SECS=300

# ─── B2B Lead notifications ───────────────────────────────────
# Email address(es) that receive an internal alert when a new demo
# request comes in. Comma-separated for multiple recipients.
# Leave empty to skip the notification (lead is still saved to DB).
LEAD_NOTIFY_EMAIL=sales@yourdomain.com

# ─── HMAC signing key ─────────────────────────────────────────
# Used to sign share-report, certificate, and score-comparison tokens.
# Must be set or the server will refuse to start (Zod enforces min length 1).
# Generate with: openssl rand -hex 32
#
# ⚠ ROTATION WARNING: all three features (share links, certificates,
# score-comparison links) sign tokens with this single secret. Rotating
# REPORT_SECRET invalidates every existing public link simultaneously —
# users who shared a report or challenge link before the rotation will
# see "link expired" errors. Plan rotations during low-traffic windows
# and notify users if any links are widely distributed.
REPORT_SECRET=change-me-to-a-long-random-secret

# Web Push / VAPID (P3-B: Weekly Progress Cards)
# Generate keys: npx web-push generate-vapid-keys
# Leave blank to disable push notifications (cards are still generated).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT_EMAIL=hello@vachix.in

# ─── Feature flags (backend) ──────────────────────────────────
# Bug #3 fix: the backend's humanised coach prompt is gated here, NOT by
# the frontend NEXT_PUBLIC_FF_HUMANIZED_COACH_PROMPT env var (which only
# lives in the browser bundle). Set this to 'false' to revert to the terse
# evaluation prompt style. Default: true (on).
HUMANIZE_COACH=true

# ─── Observability ───────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_RATE=0.1
# ⚠ REQUIRED IN PRODUCTION — startup fails if unset (process.exit(1)).
# Protects /health/metrics from public access. Generate with:
#   openssl rand -hex 32
METRICS_TOKEN=change-me-to-a-strong-random-value

# ─── Redis / BullMQ ──────────────────────────────────────────
# Required in production — B2B lead follow-up emails and background jobs
# (session notes, weak areas, readiness reports) will not run without it.
# The /health/ready endpoint returns 503 in production if REDIS_URL is unset.
# Railway: add the Redis plugin and copy its REDIS_URL automatically.
REDIS_URL=redis://localhost:6379

# ─── Session cap (P1-A) ───────────────────────────────────────
# Maximum number of completed sessions a free-tier user may save per IST
# calendar month. Hardcoded as SESSION_CAP_FREE = 3 in env.ts. Document
# here so the value is visible without reading source — change the constant
# in src/core/config/env.ts and re-deploy when you want to adjust the cap.
# Current value: 3  (review trigger: 500 paying users or 6 months post-launch)
# SESSION_CAP_FREE=3   ← not a real env var; adjust env.ts instead
