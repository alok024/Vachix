{
  "name": "vachix-api",
  "version": "5.1.0",
  "main": "dist/app.js",
  "scripts": {
    "build":         "tsc",
    "start":         "node dist/app.js",
    "worker":        "node dist/worker.js",
    "dev":           "ts-node-dev --respawn --transpile-only src/app.ts",
    "test":          "jest --forceExit --detectOpenHandles",
    "test:coverage": "jest --coverage --forceExit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs":              "^2.4.3",
    "bullmq":                "^5.4.2",
    "cookie-parser":         "^1.4.6",
    "cors":                  "^2.8.5",
    "dotenv":                "^16.3.1",
    "express":               "^4.18.2",
    "express-rate-limit":    "^7.1.5",
    "helmet":                "^7.1.0",
    "ioredis":               "^5.3.2",
    "jsonwebtoken":          "^9.0.2",
    "razorpay":              "^2.9.2",
    "resend":                "^2.0.0",
    "winston":               "^3.11.0",
    "zod":                   "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs":     "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors":         "^2.8.17",
    "@types/express":      "^4.17.21",
    "@types/jest":         "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node":         "^20.11.5",
    "@types/supertest":    "^6.0.2",
    "jest":                "^29.7.0",
    "supertest":           "^6.3.4",
    "ts-jest":             "^29.1.1",
    "typescript":          "^5.3.3"
  },
  "optionalDependencies": {
    "@sentry/node": "^7.99.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
